# KAVANA Assistant — Configuración
# Copia este archivo como .env y edita los valores

# LLM Provider (OpenRouter recomendado para modelos gratuitos)
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=meta-llama/llama-3.1-8b-instruct
LLM_BASE_URL=https://openrouter.ai/api/v1

# Alternativa: OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=

# JWT Secret (cambiar en producción)
JWT_SECRET=kavana-assistant-prod-secret-change-me

# Usuarios adicionales (opcional)
# ASSISTANT_USERS=[{"email":"supervisor@fabrica.com","password":"pass123","name":"Supervisor","role":"supervisor"}]

# ChromaDB
CHROMA_DB_PATH=/app/chromadb
